{
  "metadata": {
    "name": "Hause Design System",
    "version": "0.1.0",
    "description": "Design tokens for Hause Collective products",
    "locked": true,
    "decisions": {
      "fontStack": "Almarena Neue (display) + General Sans (sans) + Boska (serif)",
      "colorTone": "Warm cream aesthetic (#ede8e3 foreground, #161210 surfaces)",
      "interactions": "Bold/tactile with scale, shadow, glow effects",
      "spacingBase": "8px unit scale",
      "theme": "Dark mode default"
    }
  },
  "colors": {
    "primary": "#ff4e64",
    "primaryHover": "#ff6b7d",
    "primaryActive": "#ff3a4f",
    "background": "#0a0908",
    "surface": "#100e0c",
    "surfaceHover": "#16120f",
    "foreground": "#ede8e3",
    "foregroundMuted": "#6b6460",
    "border": "rgba(255, 240, 220, 0.08)",
    "borderHover": "rgba(255, 240, 220, 0.16)",
    "borderFocus": "rgba(255, 78, 100, 0.4)",
    "gray": {
      "50": "#fafaf9",
      "100": "#f5f5f3",
      "200": "#ede8e3",
      "300": "#d4cfc7",
      "400": "#a89f96",
      "500": "#8b8178",
      "600": "#6b6460",
      "700": "#544d45",
      "800": "#3d3632",
      "900": "#1a1714"
    },
    "semantic": {
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "info": "#3b82f6"
    }
  },
  "typography": {
    "fontFamily": {
      "display": "'Almarena Neue', system-ui, sans-serif",
      "sans": "'General Sans', system-ui, -apple-system, sans-serif",
      "serif": "'Boska', Georgia, serif",
      "mono": "'Monaco', 'Courier New', monospace"
    },
    "fontSize": {
      "xs": ["0.75rem", { "lineHeight": "1rem" }],
      "sm": ["0.875rem", { "lineHeight": "1.25rem" }],
      "base": ["1rem", { "lineHeight": "1.5rem" }],
      "lg": ["1.125rem", { "lineHeight": "1.75rem" }],
      "xl": ["1.25rem", { "lineHeight": "1.75rem" }],
      "2xl": ["1.5rem", { "lineHeight": "2rem" }],
      "3xl": ["1.875rem", { "lineHeight": "2.25rem" }],
      "4xl": ["2.25rem", { "lineHeight": "2.5rem" }],
      "5xl": ["3rem", { "lineHeight": "3.5rem" }],
      "6xl": ["3.75rem", { "lineHeight": "4.5rem" }]
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.6
    },
    "letterSpacing": {
      "tight": "-0.02em",
      "normal": "0em",
      "wide": "0.02em"
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.5rem",
    "2": "1rem",
    "3": "1.5rem",
    "4": "2rem",
    "6": "3rem",
    "8": "4rem",
    "10": "5rem",
    "12": "6rem",
    "16": "8rem",
    "20": "10rem",
    "24": "12rem",
    "32": "16rem"
  },
  "borderRadius": {
    "sm": "0.375rem",
    "base": "0.5rem",
    "md": "0.75rem",
    "lg": "1rem",
    "xl": "1.25rem",
    "2xl": "1.5rem",
    "3xl": "2rem",
    "full": "9999px"
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "base": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
    "md": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
    "lg": "0 10px 25px -5px rgba(255, 78, 100, 0.35)",
    "xl": "0 15px 30px -5px rgba(255, 78, 100, 0.45)",
    "glow": "0 0 20px rgba(255, 78, 100, 0.2)",
    "glowLg": "0 0 40px rgba(255, 78, 100, 0.3)"
  },
  "transitions": {
    "fast": {
      "duration": "0.12s",
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "normal": {
      "duration": "0.2s",
      "easing": "ease"
    },
    "slow": {
      "duration": "0.3s",
      "easing": "ease"
    }
  },
  "interactions": {
    "button": {
      "hover": {
        "scale": 1.02,
        "shadowAdd": "lg"
      },
      "active": {
        "scale": 0.96,
        "shadowRemove": true
      },
      "focus": {
        "outline": "2px solid currentColor",
        "outlineOffset": "2px"
      }
    },
    "card": {
      "hover": {
        "translateY": "-2px",
        "borderColorAdd": "borderHover"
      }
    },
    "input": {
      "focus": {
        "borderColor": "borderFocus",
        "shadowAdd": "0 0 0 3px rgba(255, 78, 100, 0.1)"
      }
    }
  }
}
